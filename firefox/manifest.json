{
  "manifest_version": 3,
  "name": "URL Relay",
  "version": "1.0.0",
  "description": "Detecta y envía streams de video, enlaces y páginas a tu propio webhook. Herramienta de productividad para desarrolladores.",
  "browser_specific_settings": {
    "gecko": {
      "id": "url-relay-kefplkpc@url-relay",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "cookies",
    "webRequest",
    "scripting",
    "notifications",
    "clipboardWrite"
  ],
  "optional_permissions": ["downloads"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src *"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-scanner.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "URL Relay",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
